---
import { version, dmgUrls } from '../lib/download'

interface Props {
    variant: 'hero' | 'pricing'
    class?: string
}

const { variant, class: className = '' } = Astro.props
---

<div class:list={['download-split-btn', `download-split-btn--${variant}`, className]} data-download-split-btn>
    <a
        href={dmgUrls.universal}
        data-download-link
        data-dmg-arm={dmgUrls.aarch64}
        data-dmg-intel={dmgUrls.x86_64}
        data-umami-event="download"
        data-umami-event-arch="universal"
        data-umami-event-version={version}
        data-umami-event-source={variant}
        class:list={[
            'download-split-btn__main',
            { glow: variant === 'hero' },
        ]}
    >
        <svg class="download-split-btn__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <span class="download-split-btn__stack">
            <span class="download-split-btn__label" data-download-label>
                {variant === 'hero' ? `Download v${version} for macOS` : `Download`}
            </span>
            {variant === 'hero' && (
                <span class="download-split-btn__sub" data-download-arch-hint></span>
            )}
        </span>
    </a>

    <button
        type="button"
        class="download-split-btn__chevron"
        aria-haspopup="true"
        aria-expanded="false"
        aria-label="Other architecture options"
        title="Other architecture options"
        data-download-chevron
    >
        <svg class="download-split-btn__chevron-svg" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path
                d="M2.5 3.5L5 7 7.5 3.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
        </svg>
    </button>

    <div class="download-split-btn__dropdown" role="menu" hidden data-download-dropdown>
        <a href={dmgUrls.aarch64} role="menuitem" tabindex="-1" data-arch="aarch64" class="download-split-btn__option" data-umami-event="download" data-umami-event-arch="aarch64" data-umami-event-version={version} data-umami-event-source="dropdown">
            <svg class="download-split-btn__option-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span class="download-split-btn__option-name">Apple Silicon</span>
        </a>
        <a href={dmgUrls.x86_64} role="menuitem" tabindex="-1" data-arch="x86_64" class="download-split-btn__option" data-umami-event="download" data-umami-event-arch="x86_64" data-umami-event-version={version} data-umami-event-source="dropdown">
            <svg class="download-split-btn__option-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span class="download-split-btn__option-name">Intel</span>
        </a>
        <a href={dmgUrls.universal} role="menuitem" tabindex="-1" data-arch="universal" class="download-split-btn__option" data-umami-event="download" data-umami-event-arch="universal" data-umami-event-version={version} data-umami-event-source="dropdown">
            <svg class="download-split-btn__option-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            <span class="download-split-btn__option-name">Universal</span>
        </a>
    </div>

    <!-- No-JS fallback: show all three links -->
    <noscript>
        <div class="download-split-btn__noscript">
            <a href={dmgUrls.aarch64}>Apple Silicon</a>
            <a href={dmgUrls.x86_64}>Intel</a>
            <a href={dmgUrls.universal}>Universal</a>
        </div>
    </noscript>
</div>

<style>
    /* Split button layout */
    .download-split-btn {
        position: relative;
        display: inline-flex;
        align-items: stretch;
        border-radius: 0.75rem;
        z-index: 1;
    }

    .download-split-btn[data-open] {
        z-index: 60;
    }

    .download-split-btn--pricing {
        border-radius: 0.5rem;
    }

    /* Main download link */
    .download-split-btn__main {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: var(--color-accent);
        color: var(--color-accent-contrast);
        text-decoration: none;
        transition:
            background-color var(--duration-normal),
            border-radius 150ms ease;
        border-radius: inherit;
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }

    .download-split-btn[data-open] .download-split-btn__main {
        border-bottom-left-radius: 0;
    }

    .download-split-btn__main:hover {
        background: var(--color-accent-hover);
    }

    .download-split-btn__main:focus-visible {
        outline: 2px solid var(--color-text-primary);
        outline-offset: 2px;
        z-index: 1;
    }

    /* Chevron trigger */
    .download-split-btn__chevron {
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-accent);
        color: var(--color-accent-contrast);
        border: none;
        border-left: 1px solid rgba(20, 19, 15, 0.2);
        cursor: pointer;
        transition:
            background-color var(--duration-normal),
            border-radius 150ms ease;
        border-radius: inherit;
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    .download-split-btn[data-open] .download-split-btn__chevron {
        border-bottom-right-radius: 0;
    }

    .download-split-btn__chevron:hover {
        background: var(--color-accent-hover);
    }

    .download-split-btn__chevron:focus-visible {
        outline: 2px solid var(--color-text-primary);
        outline-offset: 2px;
        z-index: 1;
    }

    .download-split-btn__chevron-svg {
        width: 10px;
        height: 10px;
        transition: transform 150ms ease;
    }

    .download-split-btn__chevron[aria-expanded='true'] .download-split-btn__chevron-svg {
        transform: rotate(180deg);
    }

    /* Hero variant (large) */
    .download-split-btn--hero .download-split-btn__main {
        padding: 1rem 2rem;
        font-size: 1.125rem;
        font-weight: 600;
    }

    .download-split-btn--hero .download-split-btn__chevron {
        padding: 1rem 0.875rem;
    }

    .download-split-btn--hero .download-split-btn__icon {
        width: 1.25rem;
        height: 1.25rem;
        flex-shrink: 0;
    }

    .download-split-btn--hero {
        transition: transform var(--duration-normal);
    }

    .download-split-btn--hero:hover {
        transform: scale(1.02);
    }

    /* Pricing variant */
    .download-split-btn--pricing .download-split-btn__main {
        padding: 0.75rem 1.5rem;
        font-weight: 600;
    }

    .download-split-btn--pricing .download-split-btn__chevron {
        padding: 0.75rem;
    }

    .download-split-btn--pricing .download-split-btn__icon {
        width: 1rem;
        height: 1rem;
        flex-shrink: 0;
    }

    /* Label stack */
    .download-split-btn__stack {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .download-split-btn__label {
        font-weight: 600;
    }

    .download-split-btn__sub {
        font-size: 0.8125rem;
        opacity: 0.8;
    }

    /* Dropdown */
    .download-split-btn__dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 50;
        border-radius: 0 0 0.5rem 0.5rem;
        border: 1px solid var(--color-border);
        border-top: none;
        background: var(--color-surface-elevated);
        padding: 4px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
        animation: download-dropdown-in 150ms ease-out;
        text-align: left;
    }

    .download-split-btn__option {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        color: var(--color-text-primary);
        text-decoration: none;
        border-radius: 0.375rem;
        transition: background-color 150ms;
        white-space: nowrap;
    }

    .download-split-btn__option-icon {
        width: 0.875rem;
        height: 0.875rem;
        flex-shrink: 0;
        opacity: 0.5;
    }

    .download-split-btn__option-name {
        flex: 1;
    }

    .download-split-btn__option:hover,
    .download-split-btn__option:focus {
        background: var(--color-surface);
        outline: none;
    }

    .download-split-btn__option:focus-visible {
        background: var(--color-surface);
        outline: 2px solid var(--color-accent);
        outline-offset: -2px;
    }

    /* Recommended indicator (set by arch detection script) */
    .download-split-btn__option[data-recommended] .download-split-btn__option-name::after {
        content: ' \2713';
        color: var(--color-accent-text);
        font-size: 0.75rem;
    }

    /* No-JS fallback */
    .download-split-btn__noscript {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
        font-size: 0.875rem;
    }

    .download-split-btn__noscript a {
        color: var(--color-accent-text);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .download-split-btn__noscript a:hover {
        color: var(--color-accent-hover);
    }

    @keyframes download-dropdown-in {
        from {
            opacity: 0;
            transform: translateY(-4px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .download-split-btn--hero {
            transition: none;
        }

        .download-split-btn--hero:hover {
            transform: none;
        }

        .download-split-btn__dropdown {
            animation: none;
        }

        .download-split-btn__chevron-svg {
            transition: none;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll<HTMLElement>('[data-download-split-btn]').forEach((wrapper) => {
            const chevron = wrapper.querySelector<HTMLButtonElement>('[data-download-chevron]')
            const dropdown = wrapper.querySelector<HTMLElement>('[data-download-dropdown]')
            if (!chevron || !dropdown || chevron.dataset.bound) return
            chevron.dataset.bound = 'true'

            const open = () => {
                // Close any other open dropdowns first
                document.querySelectorAll<HTMLElement>('[data-download-dropdown]').forEach((d) => {
                    if (d !== dropdown) {
                        d.hidden = true
                        const otherWrapper = d.closest<HTMLElement>('[data-download-split-btn]')
                        otherWrapper?.querySelector('[data-download-chevron]')?.setAttribute('aria-expanded', 'false')
                        if (otherWrapper) delete otherWrapper.dataset.open
                    }
                })
                dropdown.hidden = false
                chevron.setAttribute('aria-expanded', 'true')
                wrapper.dataset.open = ''
            }

            const close = () => {
                dropdown.hidden = true
                chevron.setAttribute('aria-expanded', 'false')
                delete wrapper.dataset.open
            }

            chevron.addEventListener('click', (e: MouseEvent) => {
                e.preventDefault()
                e.stopPropagation()
                dropdown.hidden ? open() : close()
            })

            document.addEventListener('click', (e: MouseEvent) => {
                if (!wrapper.contains(e.target as Node)) close()
            })

            document.addEventListener('keydown', (e: KeyboardEvent) => {
                if (e.key === 'Escape' && !dropdown.hidden) {
                    close()
                    chevron.focus()
                }
            })

            dropdown.addEventListener('keydown', (e: KeyboardEvent) => {
                const items = [...dropdown.querySelectorAll<HTMLElement>('[role="menuitem"]')]
                const idx = items.indexOf(document.activeElement as HTMLElement)
                if (e.key === 'ArrowDown') {
                    e.preventDefault()
                    items[(idx + 1) % items.length]?.focus()
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault()
                    items[(idx - 1 + items.length) % items.length]?.focus()
                }
            })

            chevron.addEventListener('keydown', (e: KeyboardEvent) => {
                if ((e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') && dropdown.hidden) {
                    e.preventDefault()
                    open()
                    dropdown.querySelector<HTMLElement>('[role="menuitem"]')?.focus()
                }
            })
        })
    })
</script>
