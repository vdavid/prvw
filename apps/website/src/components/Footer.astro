---
const currentYear = new Date().getFullYear()
---

<footer class="border-t border-[var(--color-border-subtle)] px-6 py-12 md:px-12 lg:px-20">
    <div class="mx-auto max-w-5xl">
        <div
            class="flex flex-wrap items-center justify-center gap-x-1 text-sm text-[var(--color-text-tertiary)]"
        >
            <span>© {currentYear} David Veszelovszki ·</span>
            <a
                href="https://github.com/vdavid/prvw"
                target="_blank"
                rel="noopener noreferrer"
                class="underline decoration-[var(--color-border)] underline-offset-2 transition-colors hover:text-[var(--color-text-primary)] hover:decoration-[var(--color-text-tertiary)]"
                >GitHub</a
            >
            <span>·</span>
            <a
                href="https://getcmdr.com"
                target="_blank"
                rel="noopener noreferrer"
                class="underline decoration-[var(--color-border)] underline-offset-2 transition-colors hover:text-[var(--color-text-primary)] hover:decoration-[var(--color-text-tertiary)]"
                >Cmdr</a
            >
            <span>·</span>
            <a
                href="https://veszelovszki.com"
                target="_blank"
                rel="noopener noreferrer"
                class="underline decoration-[var(--color-border)] underline-offset-2 transition-colors hover:text-[var(--color-text-primary)] hover:decoration-[var(--color-text-tertiary)]"
                >veszelovszki.com</a
            >
            <span>·</span>
            <a
                href="/terms-and-conditions"
                class="underline decoration-[var(--color-border)] underline-offset-2 transition-colors hover:text-[var(--color-text-primary)] hover:decoration-[var(--color-text-tertiary)]"
                >Terms</a
            >
            <span>·</span>
            <a
                href="/privacy-policy"
                class="underline decoration-[var(--color-border)] underline-offset-2 transition-colors hover:text-[var(--color-text-primary)] hover:decoration-[var(--color-text-tertiary)]"
                >Privacy</a
            >
        </div>
    </div>
</footer>
