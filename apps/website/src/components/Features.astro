---
const features = [
    {
        title: 'Instant display',
        description: 'Open a photo and it appears. No splash screen, no loading spinner. The image is on screen before you can blink.',
        icon: 'bolt',
    },
    {
        title: 'GPU-accelerated zoom and pan',
        description: 'Scroll to zoom (centered on your cursor), click-drag to pan. All on the GPU, so it feels buttery smooth at any resolution.',
        icon: 'zoom',
    },
    {
        title: 'Background preloading',
        description: 'Adjacent images are decoded in background threads and ready to go. Press an arrow key and the next photo is already there.',
        icon: 'layers',
    },
    {
        title: 'Keyboard-first',
        description: 'Arrow keys to navigate, +/- to zoom, 0 to fit, F11 for fullscreen, ESC to close. Your hands stay where they are.',
        icon: 'keyboard',
    },
    {
        title: 'Native menus',
        description: 'Real macOS menus with real keyboard shortcuts. Feels like it belongs on your Mac because it does.',
        icon: 'mac',
    },
    {
        title: 'Accurate colors',
        description: 'Embedded ICC profiles (Adobe RGB, ProPhoto, Display P3) are converted to your monitor\'s native color space. Wide-gamut P3 displays show the full range. Drag between monitors and it re-converts on the fly.',
        icon: 'color',
    },
]
---

<section id="features" class="relative px-6 py-(--spacing-section) md:px-12">
    <div class="mx-auto max-w-5xl">
        <h2 class="mb-4 text-2xl font-bold tracking-tight md:text-3xl">What makes it different</h2>
        <p class="mb-12 max-w-2xl text-[var(--color-text-secondary)]">
            Prvw does one thing: show you your images. No editing, no library management, no cloud sync. It opens a
            file and gets out of the way.
        </p>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {
                features.map((feature) => (
                    <div class="group rounded-xl border border-[var(--color-border-subtle)] bg-[var(--color-surface)] p-6 transition-all duration-300 hover:border-[var(--color-border)] hover:bg-[var(--color-surface-elevated)]">
                        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent)]/10">
                            {feature.icon === 'bolt' && (
                                <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                                </svg>
                            )}
                            {feature.icon === 'zoom' && (
                                <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
                                </svg>
                            )}
                            {feature.icon === 'layers' && (
                                <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3" />
                                </svg>
                            )}
                            {feature.icon === 'keyboard' && (
                                <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />
                                </svg>
                            )}
                            {feature.icon === 'mac' && (
                                <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />
                                </svg>
                            )}
                            {feature.icon === 'color' && (
                                <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" />
                                </svg>
                            )}
                        </div>
                        <h3 class="mb-2 font-semibold">{feature.title}</h3>
                        <p class="text-sm leading-relaxed text-[var(--color-text-secondary)]">{feature.description}</p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
