---
import DownloadButton from './DownloadButton.astro'
---

<section id="pricing" class="relative px-6 py-(--spacing-section) md:px-12">
    <div class="mx-auto max-w-5xl">
        <h2 class="mb-4 text-2xl font-bold tracking-tight md:text-3xl">Pricing</h2>
        <p class="mb-12 max-w-2xl text-[var(--color-text-secondary)]">
            Use Prvw for free at home. Pay if you're using it at work. That's the whole deal.
        </p>

        <div class="grid gap-6 md:grid-cols-2 md:max-w-3xl">
            <!-- Personal -->
            <div
                class="relative overflow-hidden rounded-xl border border-[var(--color-accent)]/30 bg-[var(--color-surface)] p-8"
            >
                <!-- Accent glow top edge -->
                <div
                    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[var(--color-accent)]"
                >
                </div>

                <p class="mb-1 text-sm font-semibold uppercase tracking-wider text-[var(--color-accent)]">Personal</p>
                <div class="mb-4 flex items-baseline gap-1">
                    <span class="text-4xl font-bold">Free</span>
                </div>
                <p class="mb-6 text-sm text-[var(--color-text-secondary)]">
                    No limits, no nags, no time trial. Yours to keep.
                </p>

                <ul class="mb-8 space-y-3 text-sm">
                    <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span class="text-[var(--color-text-secondary)]">All features included</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span class="text-[var(--color-text-secondary)]">All updates</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span class="text-[var(--color-text-secondary)]">Free forever</span>
                    </li>
                </ul>

                <DownloadButton variant="pricing" class="w-full" />
            </div>

            <!-- Commercial -->
            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8">
                <p class="mb-1 text-sm font-semibold uppercase tracking-wider text-[var(--color-sub-accent)]">
                    Commercial
                </p>
                <div class="mb-4 flex items-baseline gap-1">
                    <span class="text-4xl font-bold">$29</span>
                    <span class="text-[var(--color-text-secondary)]">/year per user</span>
                </div>
                <p class="mb-6 text-sm text-[var(--color-text-secondary)]">
                    For use at work, in a business, or in any commercial setting.
                </p>

                <ul class="mb-8 space-y-3 text-sm">
                    <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-sub-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span class="text-[var(--color-text-secondary)]">Everything in Personal</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-sub-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span class="text-[var(--color-text-secondary)]">Commercial license</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-sub-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span class="text-[var(--color-text-secondary)]">Support the project</span>
                    </li>
                </ul>

                <span
                    class="inline-flex w-full items-center justify-center rounded-lg border border-[var(--color-border)] px-6 py-3 font-semibold text-[var(--color-text-secondary)]"
                >
                    Coming soon
                </span>
            </div>
        </div>

        <p class="mt-8 text-sm text-[var(--color-text-tertiary)]">
            Prvw is source-available under the BSL 1.1 license. The code becomes fully open source after three years.
        </p>
    </div>
</section>
