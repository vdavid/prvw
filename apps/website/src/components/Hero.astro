---
import DownloadButton from './DownloadButton.astro'
---

<section class="hero-section relative overflow-hidden px-6 pt-16 md:px-12 lg:px-20">
    <!-- Background gradient - sky blue glow from top -->
    <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(77,166,255,0.12),transparent)]"
    >
    </div>

    <!-- Grid pattern overlay -->
    <div
        class="pointer-events-none absolute inset-0 bg-[linear-gradient(var(--color-border-subtle)_1px,transparent_1px),linear-gradient(90deg,var(--color-border-subtle)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,black,transparent)]"
    >
    </div>

    <div class="relative z-10 mx-auto max-w-5xl pt-16 text-left md:pt-28">
        <!-- Badge -->
        <div
            class="animate-blur-in stagger-1 mb-8 inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-1.5"
        >
            <span class="h-2 w-2 animate-pulse rounded-full bg-[var(--color-accent)]"></span>
            <span class="text-sm text-[var(--color-text-secondary)]">macOS native, built in Rust</span>
        </div>

        <!-- Headline -->
        <h1 class="mb-6 text-3xl font-bold leading-tight tracking-tight md:text-4xl lg:text-6xl">
            <span class="animate-blur-in stagger-2 inline-block">See your photos.</span>
            <span class="animate-blur-in stagger-3 inline-block gradient-text">Not loading bars.</span>
        </h1>

        <!-- Subheadline -->
        <p
            class="animate-blur-in stagger-4 mb-10 max-w-xl text-lg leading-relaxed text-[var(--color-text-secondary)] md:text-xl"
        >
            GPU-accelerated rendering, instant zoom and pan, background preloading. The next image is ready before you
            press the arrow key.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-stretch">
            <div class="animate-blur-in stagger-5 w-full sm:w-auto">
                <DownloadButton variant="hero" />
            </div>
            <a
                href="https://github.com/vdavid/prvw"
                target="_blank"
                rel="noopener noreferrer"
                class="animate-blur-in stagger-6 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-8 py-4 text-lg font-semibold transition-all duration-300 hover:border-[var(--color-text-tertiary)] hover:bg-[var(--color-surface-elevated)] sm:w-auto sm:justify-start"
            >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                    ></path>
                </svg>
                View source
            </a>
        </div>

        <!-- Pricing hint -->
        <p class="mt-8 text-sm text-[var(--color-text-tertiary)]">
            Source-available · Free forever for personal use · $29/year for commercial
        </p>
    </div>

    <!-- Screenshot placeholder -->
    <div class="relative z-10 mx-auto mt-16 max-w-4xl pb-8" aria-hidden="true">
        <div
            class="aspect-video overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]"
        >
            <div class="flex h-full flex-col items-center justify-center gap-4 p-8 text-center">
                <!-- Decorative window chrome -->
                <div class="flex gap-2 self-start pb-4">
                    <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
                    <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
                    <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
                </div>
                <!-- Placeholder content representing an image viewer -->
                <div class="flex flex-1 items-center justify-center">
                    <div class="flex flex-col items-center gap-3">
                        <svg
                            class="h-16 w-16 text-[var(--color-accent)]"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="1"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"
                            ></path>
                        </svg>
                        <p class="text-sm text-[var(--color-text-tertiary)]">Screenshot coming soon</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Glow underneath -->
        <div
            class="pointer-events-none absolute -inset-4 -z-10 rounded-2xl bg-[radial-gradient(ellipse_at_center,rgba(77,166,255,0.08),transparent_70%)]"
        >
        </div>
    </div>
</section>

<style>
    .hero-section {
        min-height: 100vh;
        position: relative;
    }

    .hero-section::after {
        content: '';
        pointer-events: none;
        z-index: 5;
        background: linear-gradient(to bottom, transparent 70%, var(--color-background) 100%);
        position: absolute;
        inset: 0;
    }
</style>
