---
import DownloadButton from './DownloadButton.astro'
---

<section class="hero-section relative overflow-hidden px-6 pt-16 md:px-12 lg:px-20">
    <!-- Background gradient - sky blue glow from top -->
    <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(77,166,255,0.12),transparent)]"
    >
    </div>

    <!-- Grid pattern overlay -->
    <div
        class="pointer-events-none absolute inset-0 bg-[linear-gradient(var(--color-border-subtle)_1px,transparent_1px),linear-gradient(90deg,var(--color-border-subtle)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,black,transparent)]"
    >
    </div>

    <div class="relative z-10 mx-auto max-w-5xl pt-16 text-left md:pt-28">
        <!-- Animated name: Preview.app → Prvw -->
        <div class="relative mb-4">
            <div
                class="name-anim text-5xl font-bold leading-none tracking-tight md:text-6xl lg:text-8xl"
                aria-label="Prvw"
            >
                <span class="name-anim__static">P</span
                ><span class="name-anim__static">r</span
                ><span class="name-anim__fade" style="--fade-delay: 0.9s">e</span
                ><span class="name-anim__static">v</span
                ><span class="name-anim__fade" style="--fade-delay: 0.5s">i</span
                ><span class="name-anim__fade" style="--fade-delay: 0.7s">e</span
                ><span class="name-anim__static">w</span
                ><span class="name-anim__fade" style="--fade-delay: 1.4s">.</span
                ><span class="name-anim__fade" style="--fade-delay: 1.6s">a</span
                ><span class="name-anim__fade" style="--fade-delay: 1.8s">p</span
                ><span class="name-anim__fade" style="--fade-delay: 2.0s">p</span>
            </div>

            <!-- Badge: hidden until name animation finishes, then fades in -->
            <div
                id="rust-badge"
                class="badge-rust absolute right-0 top-1 items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 md:top-2 lg:top-3"
            >
                <span class="h-2 w-2 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-sm text-[var(--color-text-secondary)]">Powered by Rust</span>
            </div>
        </div>

        <!-- Headline -->
        <h1 class="mb-6 text-3xl font-bold leading-tight tracking-tight md:text-4xl lg:text-6xl">
            <span class="animate-blur-in stagger-2 inline-block">Browse your pics</span>
            <span class="animate-blur-in stagger-3 inline-block gradient-text">like a breeze</span>
        </h1>

        <!-- Subheadline -->
        <p
            class="animate-blur-in stagger-4 mb-10 max-w-xl text-lg leading-relaxed text-[var(--color-text-secondary)] md:text-xl"
        >
            GPU-accelerated rendering, instant zoom and pan, background preloading. The next image is ready before you
            press the arrow key.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-stretch">
            <div class="animate-blur-in stagger-5 w-full sm:w-auto">
                <DownloadButton variant="hero" />
            </div>
            <a
                href="https://github.com/vdavid/prvw"
                target="_blank"
                rel="noopener noreferrer"
                class="animate-blur-in stagger-6 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-8 py-4 text-lg font-semibold transition-all duration-300 hover:border-[var(--color-text-tertiary)] hover:bg-[var(--color-surface-elevated)] sm:w-auto sm:justify-start"
            >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                    ></path>
                </svg>
                View source
            </a>
        </div>

        <!-- Pricing hint -->
        <p class="mt-8 text-sm text-[var(--color-text-tertiary)]">
            Source-available · Free during development · $29/year once stable
        </p>
    </div>

    <!-- Screenshot: 65px @2x shadow per side = 32.5px logical. Negative margins pull
         shadows outside the content column so the solid window edges align with body text. -->
    <div class="relative z-10 mx-auto mt-16 max-w-5xl pb-8">
        <img
            src="/hero-screenshot.webp"
            alt="Prvw displaying a photo with instant zoom and navigation"
            width="2012"
            height="1415"
            class="w-[calc(100%+6.46%)] max-w-none -mx-[3.23%]"
            loading="eager"
        />
        <!-- Glow underneath -->
        <div
            class="pointer-events-none absolute -inset-4 -z-10 rounded-2xl bg-[radial-gradient(ellipse_at_center,rgba(77,166,255,0.08),transparent_70%)]"
        >
        </div>
    </div>
</section>

<style>
    .hero-section {
        min-height: 100vh;
        position: relative;
    }

    .hero-section::after {
        content: '';
        pointer-events: none;
        z-index: 5;
        background: linear-gradient(to bottom, transparent 70%, var(--color-background) 100%);
        position: absolute;
        inset: 0;
    }

    /* Name animation: Preview.app → Prvw */
    .name-anim__static,
    .name-anim__fade {
        display: inline-block;
    }

    .name-anim__fade {
        overflow: clip;
        animation: name-letter-out 1s ease-in-out both;
        animation-delay: var(--fade-delay);
    }

    @keyframes name-letter-out {
        0%, 10% {
            color: var(--color-text-primary);
            opacity: 1;
            max-width: 0.7em;
        }
        18% {
            color: #9aaab8;
            opacity: 1;
            max-width: 0.7em;
        }
        30% {
            color: #3a5f8a;
            opacity: 1;
            max-width: 0.7em;
        }
        40% {
            color: #1a3464;
            opacity: 1;
            max-width: 0.7em;
        }
        65% {
            color: #1a3464;
            opacity: 0;
            max-width: 0.7em;
        }
        100% {
            color: #1a3464;
            opacity: 0;
            max-width: 0;
        }
    }

    /* Badge: hidden until JS reveals it after the name animation */
    .badge-rust {
        display: none;
        opacity: 0;
        transition: opacity 0.5s ease-out;
    }

    .badge-rust.visible {
        opacity: 1;
    }

    @media (prefers-reduced-motion: reduce) {
        .name-anim__fade {
            animation: none;
            display: none;
        }

        .badge-rust {
            display: inline-flex;
            opacity: 1;
            transition: none;
        }
    }
</style>

<script>
    const badge = document.getElementById('rust-badge')
    if (badge) {
        setTimeout(() => {
            badge.style.display = 'inline-flex'
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    badge.classList.add('visible')
                })
            })
        }, 3000)
    }
</script>
