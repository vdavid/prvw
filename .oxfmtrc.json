{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "all",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "printWidth": 120,
    "proseWrap": "always",
    "sortPackageJson": false,
    "ignorePatterns": [
        "node_modules/",
        "**/dist/",
        "**/build/",
        "**/.svelte-kit/",
        "**/src-tauri/",
        "**/target/",
        "pnpm-lock.yaml"
    ]
}
